# Legalis MCP Server — environment variables
# Copy to .env and fill in the values.
# In production, authentication is handled via `legalis-mcp auth` (OAuth browser flow).
# These vars are only needed for CI/testing environments.

# Backend base URL (defaults to production)
LEGALIS_API_URL=https://hai-production-612f.up.railway.app

# For automated tests: provide a pre-issued token (optional — use `legalis-mcp auth` normally)
LEGALIS_ACCESS_TOKEN=
LEGALIS_REFRESH_TOKEN=

# Credentials file location (default: ~/.legalis/credentials.json)
# LEGALIS_CREDENTIALS_FILE=~/.legalis/credentials.json

# OAuth callback port (default: 3742)
# LEGALIS_OAUTH_PORT=3742
